         <item>
          <widget class="QTextBrowser" name="helpTextBrowser">
           <property name="minimumSize">
            <size>
             <width>0</width>
             <height>430</height>
            </size>
           </property>
           <property name="html">
            <string>&lt;h3&gt;THỰC HIỆN&lt;/h3&gt;&lt;ol&gt;&lt;li&gt;Mở &lt;b&gt;Cài đặt&lt;/b&gt;, chọn OAuth Client và đăng nhập Google.&lt;/li&gt;&lt;li&gt;Dán link Google Sheet đích.&lt;/li&gt;&lt;li&gt;Chọn &lt;b&gt;Nhiều sheet&lt;/b&gt; hoặc &lt;b&gt;Một sheet&lt;/b&gt;.&lt;/li&gt;&lt;li&gt;Chọn hoặc kéo thả các file CSV.&lt;/li&gt;&lt;li&gt;Nhấn &lt;b&gt;Import vào Google Sheet&lt;/b&gt;.&lt;/li&gt;&lt;/ol&gt;&lt;h3&gt;NHIỀU SHEET&lt;/h3&gt;&lt;p&gt;Tên file phải theo mẫu &lt;b&gt;[Tên Google Sheet] - [Tên tab].csv&lt;/b&gt;. Mỗi file được nhập vào tab tương ứng; tab chưa có sẽ được tạo mới.&lt;/p&gt;&lt;h3&gt;MỘT SHEET&lt;/h3&gt;&lt;p&gt;Nhập tên tab trong card Google Sheet đích. Ứng dụng chỉ dùng &lt;b&gt;file nằm trên cùng&lt;/b&gt; trong danh sách CSV; các file phía dưới không được nhập.&lt;/p&gt;&lt;h3&gt;MẶC ĐỊNH&lt;/h3&gt;&lt;p&gt;Dòng đầu CSV luôn được xem là tiêu đề và tab đích luôn bị thay thế toàn bộ dữ liệu hiện tại.&lt;/p&gt;&lt;h3&gt;FILL TRANSLATE_DATA&lt;/h3&gt;&lt;p&gt;Trong card Hành động, bật tùy chọn Fill Translate_Data để sao chép vùng &lt;b&gt;D2:I2&lt;/b&gt; xuống đến hàng dữ liệu cuối của tab &lt;b&gt;Translate_Data&lt;/b&gt;. Hàng cuối được xác định theo cột A:C. Nếu tab hoặc dòng mẫu không tồn tại, import vẫn hoàn tất và Nhật ký sẽ hiển thị cảnh báo.&lt;/p&gt;&lt;h3&gt;CẬP NHẬT ỨNG DỤNG&lt;/h3&gt;&lt;p&gt;Trong bản EXE, mở &lt;b&gt;Cài đặt → Cập nhật&lt;/b&gt; để kiểm tra GitHub Releases, tải bản mới, xác minh SHA-256 và tự khởi động lại.&lt;/p&gt;</string>
           </property>
           <property name="openExternalLinks">
